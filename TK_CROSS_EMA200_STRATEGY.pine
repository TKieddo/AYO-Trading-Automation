//@version=6
strategy("TK Cross > EMA200 Strat", "TK Cross > EMA200", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=100, commission_type=strategy.commission.percent, commission_value=0.1)

// === INPUTS ===
conversionPeriods = input.int(20, minval=1, title="Conversion Line Periods", group="Ichimoku Settings")
basePeriods = input.int(60, minval=1, title="Base Line Periods", group="Ichimoku Settings")
laggingSpan2Periods = input.int(120, minval=1, title="Lagging Span 2 Periods", group="Ichimoku Settings")
displacement = input.int(30, minval=1, title="Displacement", group="Ichimoku Settings")

emaPeriod = input.int(200, minval=1, title="EMA Period", group="Moving Average")

// Position Sizing
useFixedSize = input.bool(false, title="Use Fixed Position Size", group="Risk Management")
fixedSize = input.float(100.0, minval=1.0, title="Fixed Position Size", group="Risk Management")
usePercentOfEquity = input.bool(true, title="Use % of Equity", group="Risk Management")
percentOfEquity = input.float(100.0, minval=1.0, maxval=100.0, title="% of Equity", group="Risk Management")

// Display Options
showIchimoku = input.bool(true, title="Show Ichimoku Cloud", group="Display")
showEMA = input.bool(true, title="Show EMA", group="Display")
showPerformanceTable = input.bool(true, title="Show Performance Table", group="Display")
showSignals = input.bool(true, title="Show Entry/Exit Signals", group="Display")

// === ICHIMOKU CALCULATIONS ===
donchian(len) => math.avg(ta.lowest(len), ta.highest(len))

conversionLine = donchian(conversionPeriods)
baseLine = donchian(basePeriods)
leadLine1 = math.avg(conversionLine, baseLine)
leadLine2 = donchian(laggingSpan2Periods)

// === EMA CALCULATION ===
ema200 = ta.ema(close, emaPeriod)

// === STRATEGY CONDITIONS ===
longCondition = conversionLine > baseLine and close > ema200
exitCondition = conversionLine < baseLine

// === POSITION SIZING ===
positionSize = useFixedSize ? fixedSize : (usePercentOfEquity ? (strategy.equity * percentOfEquity / 100) / close : strategy.initial_capital / close)

// === STRATEGY EXECUTION ===
if longCondition and strategy.position_size == 0
    strategy.entry("tkcross", strategy.long, qty=positionSize, comment="Long Entry")

if exitCondition and strategy.position_size > 0
    strategy.close("tkcross", comment="Exit Signal")

// === PLOTTING ===

// Ichimoku Cloud
p1 = plot(showIchimoku ? leadLine1 : na, offset=displacement, color=color.new(color.green, 0), title="Lead 1", linewidth=1)
p2 = plot(showIchimoku ? leadLine2 : na, offset=displacement, color=color.new(color.red, 0), title="Lead 2", linewidth=1)
fill(p1, p2, color=leadLine1 > leadLine2 ? color.new(color.green, 80) : color.new(color.red, 80), title="Ichimoku Cloud")

plot(showIchimoku ? conversionLine : na, color=color.new(#0496ff, 0), title="Conversion Line", linewidth=2)
plot(showIchimoku ? baseLine : na, color=color.new(#991515, 0), title="Base Line", linewidth=2)
plot(showIchimoku ? close : na, offset=-displacement, color=color.new(#459915, 0), title="Lagging Span", linewidth=2)

// EMA
plot(showEMA ? ema200 : na, color=color.new(color.purple, 0), linewidth=2, title="EMA 200")

// Entry/Exit Signals
plotshape(showSignals and longCondition and strategy.position_size == 0, title="Long Signal", style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 0), size=size.small)
plotshape(showSignals and exitCondition and strategy.position_size > 0, title="Exit Signal", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.small)

// === PERFORMANCE TABLE ===
if showPerformanceTable and barstate.islast
    var table perfTable = table.new(position.top_left, 2, 15, bgcolor=color.new(color.white, 90), border_width=1, border_color=color.new(color.gray, 50))
    
    // Title
    table.cell(perfTable, 0, 0, "Performance Metrics", text_color=color.white, bgcolor=color.new(color.blue, 0), text_size=size.normal)
    table.cell(perfTable, 1, 0, "", text_color=color.white, bgcolor=color.new(color.blue, 0))
    
    // Net Profit
    netProfit = strategy.netprofit
    netProfitColor = netProfit >= 0 ? color.green : color.red
    table.cell(perfTable, 0, 1, "Net Profit", text_color=color.black, bgcolor=color.new(color.gray, 70))
    table.cell(perfTable, 1, 1, str.tostring(netProfit, "#,###.##"), text_color=netProfitColor, bgcolor=color.new(color.white, 100))
    
    // Total Trades
    totalTrades = strategy.closedtrades
    table.cell(perfTable, 0, 2, "Total Trades", text_color=color.black, bgcolor=color.new(color.gray, 70))
    table.cell(perfTable, 1, 2, str.tostring(totalTrades), text_color=color.black, bgcolor=color.new(color.white, 100))
    
    // Winning Trades
    winningTrades = strategy.wintrades
    table.cell(perfTable, 0, 3, "Winning Trades", text_color=color.black, bgcolor=color.new(color.gray, 70))
    table.cell(perfTable, 1, 3, str.tostring(winningTrades), text_color=color.green, bgcolor=color.new(color.white, 100))
    
    // Losing Trades
    losingTrades = strategy.losstrades
    table.cell(perfTable, 0, 4, "Losing Trades", text_color=color.black, bgcolor=color.new(color.gray, 70))
    table.cell(perfTable, 1, 4, str.tostring(losingTrades), text_color=color.red, bgcolor=color.new(color.white, 100))
    
    // Win Rate
    winRate = totalTrades > 0 ? (winningTrades / totalTrades) * 100 : 0
    winRateColor = winRate >= 50 ? color.green : color.red
    table.cell(perfTable, 0, 5, "Win Rate", text_color=color.black, bgcolor=color.new(color.gray, 70))
    table.cell(perfTable, 1, 5, str.tostring(winRate, "#.##") + "%", text_color=winRateColor, bgcolor=color.new(color.white, 100))
    
    // Gross Profit
    grossProfit = strategy.grossprofit
    table.cell(perfTable, 0, 6, "Gross Profit", text_color=color.black, bgcolor=color.new(color.gray, 70))
    table.cell(perfTable, 1, 6, str.tostring(grossProfit, "#,###.##"), text_color=color.green, bgcolor=color.new(color.white, 100))
    
    // Gross Loss
    grossLoss = strategy.grossloss
    table.cell(perfTable, 0, 7, "Gross Loss", text_color=color.black, bgcolor=color.new(color.gray, 70))
    table.cell(perfTable, 1, 7, str.tostring(grossLoss, "#,###.##"), text_color=color.red, bgcolor=color.new(color.white, 100))
    
    // Profit Factor
    profitFactor = grossLoss != 0 ? grossProfit / math.abs(grossLoss) : 0
    profitFactorColor = profitFactor >= 1.5 ? color.green : profitFactor >= 1.0 ? color.orange : color.red
    table.cell(perfTable, 0, 8, "Profit Factor", text_color=color.black, bgcolor=color.new(color.gray, 70))
    table.cell(perfTable, 1, 8, str.tostring(profitFactor, "#.##"), text_color=profitFactorColor, bgcolor=color.new(color.white, 100))
    
    // Average Win
    avgWin = winningTrades > 0 ? grossProfit / winningTrades : 0
    table.cell(perfTable, 0, 9, "Avg Win", text_color=color.black, bgcolor=color.new(color.gray, 70))
    table.cell(perfTable, 1, 9, str.tostring(avgWin, "#,###.##"), text_color=color.green, bgcolor=color.new(color.white, 100))
    
    // Average Loss
    avgLoss = losingTrades > 0 ? math.abs(grossLoss) / losingTrades : 0
    table.cell(perfTable, 0, 10, "Avg Loss", text_color=color.black, bgcolor=color.new(color.gray, 70))
    table.cell(perfTable, 1, 10, str.tostring(avgLoss, "#,###.##"), text_color=color.red, bgcolor=color.new(color.white, 100))
    
    // Largest Win
    largestWin = 0.0
    if totalTrades > 0
        for i = 0 to totalTrades - 1
            tradeProfit = strategy.closedtrades.profit(i)
            if tradeProfit > largestWin
                largestWin := tradeProfit
    table.cell(perfTable, 0, 11, "Largest Win", text_color=color.black, bgcolor=color.new(color.gray, 70))
    table.cell(perfTable, 1, 11, str.tostring(largestWin, "#,###.##"), text_color=color.green, bgcolor=color.new(color.white, 100))
    
    // Largest Loss
    largestLoss = 0.0
    if totalTrades > 0
        for i = 0 to totalTrades - 1
            tradeProfit = strategy.closedtrades.profit(i)
            if tradeProfit < largestLoss
                largestLoss := tradeProfit
    table.cell(perfTable, 0, 12, "Largest Loss", text_color=color.black, bgcolor=color.new(color.gray, 70))
    table.cell(perfTable, 1, 12, str.tostring(largestLoss, "#,###.##"), text_color=color.red, bgcolor=color.new(color.white, 100))
    
    // Current Equity
    currentEquity = strategy.equity
    equityChange = ((currentEquity - strategy.initial_capital) / strategy.initial_capital) * 100
    equityColor = equityChange >= 0 ? color.green : color.red
    table.cell(perfTable, 0, 13, "Current Equity", text_color=color.black, bgcolor=color.new(color.gray, 70))
    table.cell(perfTable, 1, 13, str.tostring(currentEquity, "#,###.##") + " (" + str.tostring(equityChange, "#.##") + "%)", text_color=equityColor, bgcolor=color.new(color.white, 100))
    
    // Current Position
    currentPosition = strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "FLAT"
    positionColor = strategy.position_size > 0 ? color.green : strategy.position_size < 0 ? color.red : color.gray
    table.cell(perfTable, 0, 14, "Position", text_color=color.black, bgcolor=color.new(color.gray, 70))
    table.cell(perfTable, 1, 14, currentPosition, text_color=positionColor, bgcolor=color.new(color.white, 100))

// === ALERTS ===
alertcondition(longCondition and strategy.position_size == 0, title="Long Entry Signal", message="TK Cross > EMA200: Long Entry Signal")
alertcondition(exitCondition and strategy.position_size > 0, title="Exit Signal", message="TK Cross > EMA200: Exit Signal")

